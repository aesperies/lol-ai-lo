# ============================================================
# Lol-AI-lo — Frontend environment (NEXT_PUBLIC_* only)
# Copy to frontend/.env.local
# If NEXT_PUBLIC_SUPABASE_URL is left unset, the app runs in
# "modo desarrollo" (dev stub mode): a banner is shown and a
# simulated session with a selectable role is used so every
# page renders without Supabase.
# ============================================================

# Supabase (anon/public values only — never the service role key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend (FastAPI) base URL
NEXT_PUBLIC_API_URL=http://localhost:8000
