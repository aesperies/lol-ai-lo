# ============================================================
# Lol-AI-lo — Environment Variables
# Copy to:
#   backend/.env          (backend variables)
#   frontend/.env.local   (NEXT_PUBLIC_* + frontend variables)
# No real credentials should ever appear in code or config files.
# ============================================================

# ---------- Supabase (Database + Auth) ----------
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Service role key (backend only — NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Anon/public key (safe for frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Direct Postgres connection string (migrations / local dev)
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres

# ---------- Anthropic Claude (intake parsing + generation) ----------
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# ---------- OpenAI (embeddings for RAG) ----------
OPENAI_API_KEY=sk-your-openai-key
EMBEDDING_MODEL=text-embedding-3-small

# ---------- Google Drive (precedent storage) ----------
# Service account JSON path. If unset, local filesystem fallback is used (./storage).
GOOGLE_SERVICE_ACCOUNT_FILE=
# Root folder IDs in Drive
DRIVE_TEMPLATES_FOLDER_ID=
DRIVE_GESTORAS_FOLDER_ID=

# ---------- Resend (email notifications) ----------
# If unset, emails are logged to console instead of sent.
RESEND_API_KEY=
# All client-facing email is sent from the Lol-AI-lo Legal SLP domain
EMAIL_FROM=notificaciones@lolailolegal.es

# ---------- App ----------
# Backend base URL (used by frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Frontend base URL (used in email links)
FRONTEND_URL=http://localhost:3000
# Local storage fallback directory (when Drive is not configured)
LOCAL_STORAGE_DIR=./storage
# Set to "true" to run auth in dev-stub mode (no Supabase needed; X-Dev-User header)
DEV_AUTH_STUB=false
# Generation-job retry backoff base in seconds (delays: base*1, base*4).
# The test suite pins this to 0 for instant retries.
JOB_BACKOFF_BASE=1.0

# ---------- Billing (usage_events overage pricing) ----------
# Per-doc overage prices in EUR once the tier's monthly doc allowance is exhausted.
# TODO: tiers/prices TBD per SPEC PRICING STRUCTURE — 0 = TBD (estimated overage stays €0).
PRICE_EXIT_A_EUR=0
PRICE_EXIT_B_EUR=0

# ---------- Counsel SLA (Exit B turnaround) ----------
# Promised review turnaround in hours
SLA_REVIEW_HOURS=48
# Reminder to the assigned counsel when half the SLA has elapsed
SLA_REMINDER_HOURS=24
# Escalation to the backup counsel after SLA + 8h grace
SLA_ESCALATION_HOURS=56
# In-process periodic sweep (set to "false" to rely on POST /api/admin/sla/sweep via external cron)
SLA_SWEEP_ENABLED=true
SLA_SWEEP_INTERVAL_MINUTES=30
