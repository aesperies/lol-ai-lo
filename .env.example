# ============================================================
# Lol-AI-lo — Environment Variables
# Copy to:
#   backend/.env          (backend variables)
#   frontend/.env.local   (NEXT_PUBLIC_* + frontend variables)
# No real credentials should ever appear in code or config files.
# ============================================================

# ---------- Supabase (Database + Auth) ----------
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Service role key (backend only — NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Anon/public key (safe for frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Direct Postgres connection string (migrations / local dev)
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres

# ---------- Anthropic Claude (intake parsing + generation) ----------
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# ---------- OpenAI (embeddings for RAG) ----------
OPENAI_API_KEY=sk-your-openai-key
EMBEDDING_MODEL=text-embedding-3-small

# ---------- Google Drive (precedent storage) ----------
# Service account JSON path. If unset, local filesystem fallback is used (./storage).
GOOGLE_SERVICE_ACCOUNT_FILE=
# Root folder IDs in Drive
DRIVE_TEMPLATES_FOLDER_ID=
DRIVE_GESTORAS_FOLDER_ID=

# ---------- Resend (email notifications) ----------
# If unset, emails are logged to console instead of sent.
RESEND_API_KEY=
# All client-facing email is sent from the Lol-AI-lo Legal SLP domain
EMAIL_FROM=notificaciones@lolailolegal.es

# ---------- App ----------
# Backend base URL (used by frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Frontend base URL (used in email links)
FRONTEND_URL=http://localhost:3000
# Local storage fallback directory (when Drive is not configured)
LOCAL_STORAGE_DIR=./storage
# Set to "true" to run auth in dev-stub mode (no Supabase needed; X-Dev-User header)
DEV_AUTH_STUB=false
